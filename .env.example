# Copia a .env.local y ajusta.

VITE_DIETA_API_BASE=http://localhost:3000

# App nativa (Capacitor): para generar el AAB, copia .env.production.example → .env.production
# y pon aquí la URL HTTPS del API en producción (no uses localhost).

# Opcional: sobrescribe el correo de src/constants/contact.ts
# VITE_CONTACT_EMAIL=onavi.001+support@gmail.com

# Opcional: Sentry (errores en el navegador)
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# VITE_SENTRY_TRACES_SAMPLE_RATE=0