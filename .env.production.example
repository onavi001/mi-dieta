# Copia a .env.production antes de `npm run build` / `npm run cap:sync`.
# Obligatorio para la app Android/iOS: la WebView usa https://localhost; sin esto el cliente
# intenta http://localhost:3000 y el login falla (Failed to fetch / mixed content).

# Sustituye por la URL exacta del servicio en Render (Dashboard → tu Web Service → URL), sin barra final.
# No uses el texto de ejemplo "tu-api-en-render"; debe ser algo como: https://mi-dieta-api-xxxx.onrender.com
VITE_DIETA_API_BASE=https://REEMPLAZA_CON_TU_URL_DE_RENDER.onrender.com

# Opcional (mismas que .env.example)
# VITE_CONTACT_EMAIL=
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
